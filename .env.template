# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# HuggingFace model cache directory (optional, defaults to HF default)
# CACHE_DIR=/path/to/model/cache

# HuggingFace home directory (where token is stored)
# HF_HOME=/path/to/.hf_cache

# OpenAI API key (required for Stage 3: GPT-4o evaluation)
# OPENAI_API_KEY=sk-...

# Path to the data directory (concepts, statements, eval prompts)
# If not set, defaults to ../attention_guided_steering/data
# STEERING_DATA_DIR=/path/to/data

# Path to original code (for RFM imports). Auto-detected if not set.
# ORIGINAL_CODE_DIR=/path/to/attention_guided_steering
